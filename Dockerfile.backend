FROM python:3.11

WORKDIR /app

# Install Python dependencies
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Copy app
COPY . .

ENV PYTHONUNBUFFERED=1
ENV PORT=5000

EXPOSE 5000

# Use gunicorn for production
CMD ["sh", "-c", "uvicorn api:app --host 0.0.0.0 --port ${PORT}"]
